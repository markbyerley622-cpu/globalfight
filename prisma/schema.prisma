// ════════════════════════════════════════════════════════════════════════
//  Combat Reviews 2.0 — Prisma schema (PostgreSQL)
//  Designed for millions of records: indexed lookups, snapshot tables for
//  time-series ranking/odds data, and denormalised counters for hot reads.
// ════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────

enum Sport {
  BOXING
  MMA
  MUAY_THAI
  KICKBOXING
  K1
  BARE_KNUCKLE
  BJJ
  BJJ_NOGI
  WRESTLING
  JUDO
  TAEKWONDO
  SAMBO
  COMBAT_SAMBO
}

enum Stance {
  ORTHODOX
  SOUTHPAW
  SWITCH
}

enum FightResult {
  WIN
  LOSS
  DRAW
  NO_CONTEST
  SCHEDULED
}

enum FightMethod {
  KO
  TKO
  UD // unanimous decision
  SD // split decision
  MD // majority decision
  SUB // submission (MMA)
  DQ
  RTD // retired
  TD // technical decision
  NC
  DRAW
}

enum RankMovement {
  UP
  DOWN
  SAME
  NEW
  RETURN
}

enum SanctioningBody {
  WBA
  WBC
  IBF
  WBO
  RING // Ring Magazine
  IBO
  THE_RING
  UNDISPUTED
  BKFC // Bare Knuckle Fighting Championship (promotion-as-sanctioning-body)
  ONE // ONE Championship (promotion-as-sanctioning-body)
  PFL // Professional Fighters League (promotion-as-sanctioning-body)
  UFC // Ultimate Fighting Championship (promotion-as-sanctioning-body)
}

enum EventStatus {
  /// Admin-only. Never appears on any public surface, in search, or in the
  /// sitemap. Scraped events are never DRAFT — this is only for cards an
  /// operator is building by hand before announcing them.
  DRAFT
  ANNOUNCED
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PredictionSource {
  AI
  EXPERT
  COMMUNITY
}

enum UserRole {
  USER
  EXPERT
  EDITOR
  MODERATOR
  ADMIN
}

enum ScrapeStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ─── Reference data ─────────────────────────────────────────────────────

model WeightClass {
  id       String @id @default(cuid())
  name     String // "Heavyweight" — unique per sport, not globally
  slug     String @unique // "heavyweight", "bk-heavyweight"
  sport    Sport  @default(BOXING)
  limitLbs Float? // 200, 175, 147...
  limitKg  Float?
  order    Int // display order, heaviest = 0

  rankings  Ranking[]
  champions Champion[]
  fights    Fight[]

  @@unique([sport, name]) // names repeat across sports (Heavyweight in boxing AND bare-knuckle)
  @@index([sport, order])
}

model Language {
  id         String  @id @default(cuid())
  code       String  @unique // "en", "es", "fr"...
  name       String // "English"
  nativeName String // "English", "Español"
  rtl        Boolean @default(false)
  enabled    Boolean @default(true)
}

// ─── Fighters ───────────────────────────────────────────────────────────

model Fighter {
  id       String  @id @default(cuid())
  slug     String  @unique
  name     String
  nickname String?
  sport    Sport   @default(BOXING)

  // bio
  nationality String? // ISO-ish country name
  countryCode String? // "US", "GB", "MX"
  birthDate   DateTime?
  birthPlace  String?
  residence   String?
  heightCm    Int?
  reachCm     Int?
  stance      Stance?
  debutDate   DateTime?
  gym         String?
  promoter    String?

  // self-service ownership — set when a user signs up as a fighter or claims
  // an existing profile. One user owns at most one fighter profile.
  ownerId      String? @unique
  owner        User?   @relation("FighterOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  claimed      Boolean @default(false)
  website      String?
  instagram    String?
  twitter      String?
  contactEmail String? // public booking/contact email
  tagline      String? // hero strapline on their site
  profileKind  String  @default("fighter") // fighter | ring_girl | ring_official …
  beltRank     String? // BJJ / No-Gi
  style        String? // wrestling
  federation   String? // taekwondo
  rank         String? // judo / taekwondo

  // record (denormalised for fast reads — derived from Fight rows)
  wins        Int @default(0)
  losses      Int @default(0)
  draws       Int @default(0)
  noContests  Int @default(0)
  koWins      Int @default(0)
  koLosses    Int @default(0)
  totalRounds Int @default(0)

  // media (our own cached/processed images — never hotlinked source URLs)
  thumbUrl     String? // square ~160px (cards, rankings, search)
  imageUrl     String? // square ~512px (profile)
  heroImageUrl String? // 16:9 ~1280px (profile hero)

  // Licensed external photo (Wikimedia Commons). Displayed via the /api/img
  // proxy with the credit rendered on the profile — a source URL we hold an
  // attribution licence for, kept separate from the own-storage fields above.
  photoUrl        String? // source image URL (upload.wikimedia.org/…)
  photoSource     String? // "Wikimedia Commons"
  photoCredit     String? // author / "Artist" from the file metadata
  photoLicense    String? // e.g. "CC BY-SA 4.0"
  photoLicenseUrl String? // link to the licence deed

  // meta
  active               Boolean   @default(true)
  bio                  String?   @db.Text
  lastScrapedAt        DateTime? // any scrape touched the row
  lastProfileScrapedAt DateTime? // profile-enrichment (photo/bio) last run
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // NOTE: provenance scalars (primarySource/sourceConfidence/sourceUpdatedAt)
  // are intentionally NOT on the model yet — they'd be auto-selected by every
  // fighter query and 500 until the column exists in prod. They get added in a
  // coordinated `db:push` when persistAggregated (services/sync/run.ts) lands.

  rankings         Ranking[]
  championOf       Champion[]
  fightsAsRed      Fight[]              @relation("RedCorner")
  fightsAsBlue     Fight[]              @relation("BlueCorner")
  titles           Title[]
  rankHistory      RankSnapshot[]
  predictions      Prediction[]         @relation("PredictedWinner")
  favoritedBy      FavoriteFighter[]
  cardAwards       CardAward[]
  achievements     FighterAchievement[]
  sponsors         FighterSponsor[]
  socials          FighterSocial[]
  media            FighterMedia[]
  claims           FighterClaim[]
  externalIds      FighterExternalId[]
  aliases          FighterAlias[]
  discussionThread ForumThread?

  @@index([sport, active])
  @@index([countryCode])
  @@index([name])
  @@index([wins, losses])
  @@index([lastProfileScrapedAt]) // stale-profile detection for the enrichment queue
}

model Title {
  id        String          @id @default(cuid())
  fighterId String
  fighter   Fighter         @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  body      SanctioningBody
  weight    String // weight-class name at time of title
  wonDate   DateTime?
  lostDate  DateTime?
  current   Boolean         @default(false)

  @@index([fighterId])
  @@index([body, current])
}

// ─── Fighter-owned website content (managed by the profile owner) ────────

model FighterAchievement {
  id        String   @id @default(cuid())
  fighterId String
  fighter   Fighter  @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  title     String
  year      Int?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([fighterId, order])
}

model FighterSponsor {
  id        String  @id @default(cuid())
  fighterId String
  fighter   Fighter @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  name      String
  url       String?
  logoUrl   String?
  order     Int     @default(0)

  @@index([fighterId, order])
}

model FighterSocial {
  id        String  @id @default(cuid())
  fighterId String
  fighter   Fighter @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  platform  String // instagram | twitter | youtube | tiktok | facebook | web
  url       String

  @@unique([fighterId, platform])
}

model FighterMedia {
  id        String   @id @default(cuid())
  fighterId String
  fighter   Fighter  @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  type      String // "photo" | "video"
  url       String // stored image URL or video (YouTube/Vimeo) URL
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([fighterId, type, order])
}

// ─── Profile claiming & moderation ───────────────────────────────────────

model FighterClaim {
  id           String  @id @default(cuid())
  fighterId    String
  fighter      Fighter @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  claimantId   String
  claimant     User    @relation("ClaimsMade", fields: [claimantId], references: [id], onDelete: Cascade)
  status       String  @default("PENDING") // PENDING | APPROVED | REJECTED | INFO_REQUESTED
  evidenceType String? // website | social | email | id_document
  evidenceNote String? @db.Text

  // ── Identity evidence (passport / licence / ID card) ──────────────────────
  // Highly sensitive. Stored PRIVATE — never a public URL, never under public/.
  // We persist an opaque storage key, not a fetchable address; the bytes are
  // reachable only through an authorized, audited, streaming endpoint.
  evidenceStorageKey      String? // opaque object key; never returned to clients
  evidenceStorageProvider String? // "r2" | "blob" | "local-private"
  evidenceUploadedAt      DateTime?
  evidenceDeleteAfter     DateTime? // retention deadline; cleanup job deletes past this
  evidenceDeletedAt       DateTime?
  evidenceDeletionStatus  String? // null | PENDING | DELETED | FAILED
  evidenceDeletionError   String? // last failure reason (never the key/URL)
  evidenceScanStatus      String? // PENDING | CLEAN | INFECTED | SKIPPED
  evidenceContentType     String?
  evidenceByteSize        Int?

  /// DEPRECATED — legacy public URL from the pre-remediation implementation.
  /// Mapped to the original `evidenceUrl` column so no data is lost on db push.
  /// Nothing writes this. `scripts/remediate-claim-evidence.ts` reads it to
  /// delete the underlying public objects, then nulls it. Dropped in phase 2
  /// once every row is null (see docs/SECURITY-IDENTITY-EVIDENCE.md).
  legacyEvidenceUrl String? @map("evidenceUrl")

  reviewerId String?
  reviewer   User?     @relation("ClaimsReviewed", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote String?
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@unique([fighterId, claimantId]) // one claim per user per fighter
  @@index([status, createdAt])
  @@index([fighterId])
  @@index([evidenceDeleteAfter]) // cleanup job scans this
  @@index([evidenceDeletionStatus]) // retry scan for FAILED deletions
}

/// A value an importer WANTED to write but could not, because an operator holds
/// that field.
///
/// Without this the two systems just diverge in silence: the importer stops
/// mattering and the operator never learns the source disagrees. Recording the
/// rejected value turns a silent overwrite-prevention into a reviewable
/// decision — accept the import, or keep the manual edit.
///
/// One row per (entity, field): only the LATEST proposal is worth reviewing, so
/// a re-run replaces rather than accumulates.
model ImportConflict {
  id            String    @id @default(cuid())
  entity        String // "Event" | "Fight"
  entityId      String
  field         String
  /// What the operator's value was when the conflict was recorded.
  currentValue  String?   @db.Text
  /// What the importer proposed instead.
  importedValue String?   @db.Text
  source        String? // provider that proposed it
  resolvedAt    DateTime?
  resolution    String? // "accepted" | "kept"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([entity, entityId, field])
  @@index([entityId, resolvedAt])
  @@index([resolvedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String? // user who performed the action
  action    String // "claim.create" | "claim.approve" | …
  entity    String // "FighterClaim" | "Fighter"
  entityId  String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── Rankings (current snapshot, fast read) ─────────────────────────────

model Ranking {
  id            String      @id @default(cuid())
  weightClassId String
  weightClass   WeightClass @relation(fields: [weightClassId], references: [id], onDelete: Cascade)
  fighterId     String
  fighter       Fighter     @relation(fields: [fighterId], references: [id], onDelete: Cascade)

  isPoundForPound Boolean      @default(false)
  rank            Int
  previousRank    Int?
  movement        RankMovement @default(SAME)
  rating          Float? // 0–100 point score
  source          String       @default("import")
  updatedAt       DateTime     @updatedAt

  @@unique([weightClassId, isPoundForPound, fighterId])
  @@index([weightClassId, rank])
  @@index([isPoundForPound, rank])
}

// Time-series history — append-only, designed for millions of rows.
model RankSnapshot {
  id              String   @id @default(cuid())
  fighterId       String
  fighter         Fighter  @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  weightClass     String // denormalised string key
  isPoundForPound Boolean  @default(false)
  rank            Int
  rating          Float?
  capturedAt      DateTime @default(now())

  @@index([fighterId, capturedAt])
  @@index([weightClass, capturedAt])
}

// ─── Champions ──────────────────────────────────────────────────────────

model Champion {
  id            String          @id @default(cuid())
  fighterId     String
  fighter       Fighter         @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  weightClassId String
  weightClass   WeightClass     @relation(fields: [weightClassId], references: [id], onDelete: Cascade)
  body          SanctioningBody
  beltImageUrl  String?
  since         DateTime?
  defenses      Int             @default(0)
  current       Boolean         @default(true)

  @@unique([weightClassId, body, current])
  @@index([body])
}

// ─── Events & Fights ────────────────────────────────────────────────────

model Event {
  id               String      @id @default(cuid())
  slug             String      @unique
  name             String
  sport            Sport       @default(BOXING)
  promotion        String?
  promotionId      String? // registry promotion (identity resolution)
  promotionRef     Promotion?  @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  venue            String?
  city             String?
  country          String?
  countryCode      String?
  broadcaster      String?
  posterUrl        String?
  /// 16:9 artwork for the event hero. Distinct from posterUrl (the vertical
  /// promotional poster) — different aspect, different placement.
  heroUrl          String?
  description      String?     @db.Text
  /// IANA zone for the venue, e.g. "Asia/Bangkok". `date` stays absolute UTC;
  /// this only tells the UI which local wall-clock the card is billed at.
  timezone         String?
  eventUrl         String?
  ticketUrl        String?
  date             DateTime
  /// Broadcast block starts. Null means "derive it" (see lib/card-segments) —
  /// an operator filling these in is what turns an estimate into a fact.
  broadcastStartAt DateTime?
  prelimStartAt    DateTime?
  mainCardStartAt  DateTime?
  status           EventStatus @default(SCHEDULED)

  /// Field-level provenance. Any column an operator has edited is listed here,
  /// and the ingest pipeline refuses to overwrite it (services/sync/persist).
  ///
  /// Without this the editor is decorative: the scrapers re-run on cron and
  /// unconditionally rewrite name/date/venue/status, so every manual correction
  /// would silently revert within hours. Locking is per FIELD, not per row, so
  /// a human fixing a venue never freezes the automatic result updates.
  lockedFields String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // provenance scalars deferred — see the note on the Fighter model.

  fights           Fight[]
  externalIds      EventExternalId[]
  discussionThread ForumThread?
  followers        FavoriteEvent[]
  checkIns         CheckIn[]

  @@index([date, status])
  @@index([country])
  @@index([promotion])
  @@index([promotionId])
}

model Fight {
  id      String  @id @default(cuid())
  slug    String  @unique
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  redId  String
  red    Fighter @relation("RedCorner", fields: [redId], references: [id], onDelete: Cascade)
  blueId String
  blue   Fighter @relation("BlueCorner", fields: [blueId], references: [id], onDelete: Cascade)

  weightClassId String?
  weightClass   WeightClass? @relation(fields: [weightClassId], references: [id], onDelete: SetNull)

  scheduledRounds  Int       @default(12)
  titleFight       Boolean   @default(false)
  /// An interim belt. Separate from titleFight so the badge can read "Interim
  /// Title" — conflating them loses information a fan cares about.
  interimTitle     Boolean   @default(false)
  mainEvent        Boolean   @default(false)
  coMain           Boolean   @default(false)
  orderOnCard      Int       @default(0)
  /// Post-fight awards, entered by an operator after the card.
  performanceBonus Boolean   @default(false)
  fightOfTheNight  Boolean   @default(false)
  /// Explicit walkout time. Null means the schedule estimates it.
  estimatedStartAt DateTime?
  /// See Event.lockedFields. Critical here: the ingest pipeline rewrites
  /// orderOnCard from the SOURCE's index on every run, so drag-and-drop
  /// ordering would be destroyed by the next cron without this.
  lockedFields     String[]
  /// Which broadcast block this bout sits in: "MAIN" | "PRELIM" | "EARLY_PRELIM".
  /// Only set when a provider actually tells us. When null the schedule DERIVES a
  /// split from card size and bout order and labels it as an estimate — we never
  /// present a guessed broadcast block as fact.
  cardSegment      String?
  /// A bout pulled from the card (injury, weight miss, withdrawal). Kept rather
  /// than deleted so the change is visible to a fan who already made a pick.
  cancelled        Boolean   @default(false)
  /// Free-text note for a scratched or reshuffled bout, e.g. "Jones out (injury)
  /// — replaced by Silva". Rendered verbatim next to the bout.
  cardNote         String?

  // result
  result     FightResult  @default(SCHEDULED)
  winnerId   String? // Fighter.id or null
  method     FightMethod?
  roundEnded Int?
  timeEnded  String?
  scorecards Json? // [{judge, red, blue}]

  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  predictions     Prediction[]
  odds            OddsSnapshot[]
  picks           FightPick[]
  battles         Battle[]
  /// The bout's PUBLIC community room — every fight is its own arena.
  room            ForumThread?
  // Set once by the resolution engine after a decided bout's picks are graded
  // and consequences fanned out — the idempotency guard so it never double-awards.
  picksResolvedAt DateTime?

  @@index([date, result])
  @@index([redId])
  @@index([blueId])
  @@index([eventId, orderOnCard])
}

/// A signed-in user's pick on a single bout — the crowd-prediction primitive and
/// the North Star (WAPU) driver. One pick per user per fight (upserted). `corner`
/// is "RED" | "BLUE" (resolved against winningCorner() at fight time, not a
/// fighter FK, so it survives roster edits). `confidence` is an optional 1–5
/// star. `correct` is set by a future resolution pass to power accuracy /
/// credibility / streaks / collectible rewards — the fields the plan's habit
/// loop is built on. Distinct from CommunityMarket/Vote (generic open-ended
/// polls) and the dead editorial Prediction model.
model FightPick {
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fightId    String
  fight      Fight        @relation(fields: [fightId], references: [id], onDelete: Cascade)
  corner     String // "RED" | "BLUE"
  method     FightMethod?
  confidence Int? // 1..5
  correct    Boolean? // set when the bout resolves
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@id([userId, fightId])
  @@index([fightId, corner])
}

// ─── Predictions ────────────────────────────────────────────────────────

model Prediction {
  id       String           @id @default(cuid())
  fightId  String
  fight    Fight            @relation(fields: [fightId], references: [id], onDelete: Cascade)
  source   PredictionSource
  authorId String? // User.id for expert/community
  author   User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)

  predictedWinnerId String?
  predictedWinner   Fighter? @relation("PredictedWinner", fields: [predictedWinnerId], references: [id], onDelete: SetNull)

  redProbability   Float // 0..1
  blueProbability  Float
  methodPrediction FightMethod?
  roundPrediction  Int?
  confidence       Float?
  rationale        String?      @db.Text
  createdAt        DateTime     @default(now())

  @@index([fightId, source])
  @@index([authorId])
}

// ─── Betting intelligence (NO wagering) ─────────────────────────────────

model OddsSnapshot {
  id          String   @id @default(cuid())
  fightId     String
  fight       Fight    @relation(fields: [fightId], references: [id], onDelete: Cascade)
  bookmaker   String
  redOdds     Float // decimal odds
  blueOdds    Float
  drawOdds    Float?
  redImplied  Float // implied probability 0..1
  blueImplied Float
  capturedAt  DateTime @default(now())

  @@index([fightId, capturedAt])
  @@index([bookmaker])
}

// ─── News / CMS ─────────────────────────────────────────────────────────

model Article {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  excerpt       String?
  content       String        @db.Text
  category      String // "Breaking News", "Analysis"...
  status        ArticleStatus @default(DRAFT)
  featured      Boolean       @default(false)
  coverImageUrl String?
  sourceUrl     String? // original article URL (RSS link) — cards link out to it
  promotionId   String? // registry promotion this story is about (identity resolution)
  promotion     Promotion?    @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  authorId      String?
  author        User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?

  views       Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tags ArticleTag[]

  @@index([status, publishedAt])
  @@index([category, publishedAt])
  @@index([featured])
  @@index([promotionId, publishedAt])
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

// ─── Forums ─────────────────────────────────────────────────────────────

// A ForumCategory doubles as a Community: the official ones are seeded
// (MMA, Boxing, BJJ…) and user-created communities are added as rows with an
// ownerId. Membership lives in CommunityMember; avatar/banner/memberCount are
// the community-presentation fields.
model ForumCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  description String?
  order       Int               @default(0)
  icon        String?
  avatarUrl   String?
  bannerUrl   String?
  memberCount Int               @default(0)

  // ── Fight clubs ────────────────────────────────────────────────────────
  // A fight club IS a community that happens to meet somewhere. Rather than
  // add a parallel FightClub model with its own membership, posts and
  // moderation — three systems to keep in sync forever — a community with
  // coordinates is a fight club. Everything it already has (threads, members,
  // roles, clips) comes along for free, and `kind` is the only branch.
  /// forum | fight_club
  kind        String            @default("forum")
  city        String?
  country     String?
  countryCode String?
  latitude    Float?
  longitude   Float?
  /// When they train together — "Open sparring, Saturdays 11am".
  meetsOn     String?

  threads     ForumThread[]
  members     CommunityMember[]

  @@index([kind])
}

// One row per member of a community (a ForumCategory). role carries the
// owner/moderator flags used by later phases; Phase 1 only writes "member".
model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  community   ForumCategory @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String        @default("member") // member | moderator | owner
  createdAt   DateTime      @default(now())

  @@unique([communityId, userId])
  @@index([userId])
}

model ForumThread {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  categoryId    String
  category      ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId      String
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  pinned        Boolean       @default(false)
  locked        Boolean       @default(false)
  // discussion | fighter_post | promoter_post | announcement — drives feed
  // treatment (fighter/promoter updates surface in the community feed).
  kind          String        @default("discussion")
  views         Int           @default(0)
  replyCount    Int           @default(0)
  // Denormalised engagement counters for fast trending/feed sorts (no joins).
  shareCount    Int           @default(0)
  reactionCount Int           @default(0) // sum of reactions across the thread's posts
  // When set, this thread is the discussion for a Combat Feed video. SetNull so
  // the discussion survives if the underlying feed video is pruned.
  videoId       String?
  video         FeedVideo?    @relation(fields: [videoId], references: [id], onDelete: SetNull)
  // Entity-linked auto-threads: every fighter/promotion gets ONE discussion
  // thread (1:1, provisioned on demand). promotion is a registry slug
  // (resolvePromotion), not an FK.
  fighterId     String?       @unique
  fighter       Fighter?      @relation(fields: [fighterId], references: [id], onDelete: SetNull)
  promotion     String?       @unique
  /// The event's GENERAL room — card-wide talk that belongs to no single bout
  /// ("who's watching?", "card is running late"). The third room in the
  /// hierarchy, NOT a competitor to the fight rooms:
  ///   Event → General room
  ///   Event → Fight → Battle room + Community room
  eventId       String?       @unique
  event         Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)

  // ─── Rooms ────────────────────────────────────────────────────────────────
  // The Battle-Rooms architecture. Every FIGHT owns exactly one PUBLIC community
  // room (fightId) — the spectator layer. Every BATTLE owns exactly one PRIVATE
  // room (battleId, visibility="battle") readable and postable only by its two
  // participants. Both are ordinary ForumThreads: same posts, reactions, quotes,
  // realtime and moderation — no parallel discussion system.
  fightId    String? @unique
  fight      Fight?  @relation(fields: [fightId], references: [id], onDelete: SetNull)
  battleId   String? @unique
  battle     Battle? @relation(fields: [battleId], references: [id], onDelete: Cascade)
  /// "public" — listed in feeds/categories, world-readable.
  /// "battle"  — hidden from every listing, gated to the battle's two users.
  visibility String  @default("public")

  lastPostAt DateTime @default(now())
  createdAt  DateTime @default(now())

  posts         ForumPost[]
  subscriptions ForumSubscription[]
  bookmarks     ForumBookmark[]

  @@index([categoryId, lastPostAt])
  @@index([pinned, lastPostAt])
  @@index([kind, createdAt])
  @@index([videoId])
  @@index([createdAt])
  @@index([visibility, lastPostAt])
}

model ForumPost {
  id            String      @id @default(cuid())
  threadId      String
  thread        ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content       String      @db.Text
  likeCount     Int         @default(0) // legacy "like" count (kept in sync)
  // Embedded/uploaded media: JSON array of
  //   { type: "image"|"youtube"|"instagram"|"x"|"tiktok"|"video",
  //     url, thumbUrl?, width?, height?, caption? }
  attachments   Json?
  // Quoted-reply snapshot: the post id + author + short excerpt being quoted, so
  // the quote renders even if the original is later edited/deleted.
  quotedId      String?
  quotedAuthor  String?
  quotedExcerpt String?     @db.Text
  parentId      String? // reply-to-reply (nesting)
  edited        Boolean     @default(false)
  deleted       Boolean     @default(false) // soft-delete: keep thread shape intact
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  reactions ForumReaction[]

  @@index([threadId, createdAt])
  @@index([authorId])
}

model ForumReaction {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    @default("like") // like | fire | etc.
  createdAt DateTime  @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
}

// Follow / Subscribe a thread — the user gets it in their "Following" feed and
// (future) notifications. One row per user per thread.
model ForumSubscription {
  id        String      @id @default(cuid())
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([threadId, userId])
  @@index([userId])
}

// Bookmark / Save a thread for later (distinct from following — no feed/notify
// semantics, just a personal saved list).
model ForumBookmark {
  id        String      @id @default(cuid())
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([threadId, userId])
  @@index([userId, createdAt])
}

// Community moderation — a member flags a thread or post for review.
model ForumReport {
  id         String   @id @default(cuid())
  targetType String // "thread" | "post"
  targetId   String
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String // spam | harassment | off_topic | other
  detail     String?  @db.Text
  status     String   @default("OPEN") // OPEN | REVIEWED | DISMISSED
  createdAt  DateTime @default(now())

  @@unique([targetType, targetId, reporterId]) // one report per user per target
  @@index([status, createdAt])
  @@index([targetType, targetId])
}

/// Copyright / takedown notices.
///
/// Distinct from ForumReport: a copyright claim is a legal assertion by a rights
/// owner, needs a good-faith statement and a signature, and has a counter-notice
/// path. A community "this is spam" report has none of that.
///
/// The reporter does NOT have to be a signed-in user — a rights owner is usually a
/// stranger to the platform. Contact details are collected instead.
///
/// NOTE: this records notices and the action taken. It does NOT constitute
/// registration of a DMCA designated agent — that is an external filing with the US
/// Copyright Office, and it has not been done. See docs/EXTERNAL-COMPLIANCE-ACTIONS.md.
model CopyrightReport {
  id String @id @default(cuid())

  /// What is complained about, e.g. "clip:<id>", "forumPost:<id>", "fighter:<slug>".
  contentIdentifier String
  contentUrl        String?

  // ── The claimant ──────────────────────────────────────────────────────
  reporterName    String
  reporterEmail   String
  reporterOrg     String?
  /// The work they say was infringed.
  workDescription String   @db.Text
  /// "I am the rights owner or authorised to act for them."
  ownershipClaim  Boolean  @default(false)
  /// "I have a good-faith belief the use is not authorised."
  goodFaithClaim  Boolean  @default(false)
  /// Typed full name, standing as an electronic signature.
  signature       String
  signedAt        DateTime @default(now())

  // ── Our handling ──────────────────────────────────────────────────────
  status      String    @default("RECEIVED") // RECEIVED | REVIEWING | ACTIONED | REJECTED | COUNTER_NOTICED | RESTORED
  reviewerId  String?
  reviewer    User?     @relation("CopyrightReviewed", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote  String?   @db.Text
  actionTaken String? // removed | disabled | no_action
  actionedAt  DateTime?

  // ── Counter-notice ────────────────────────────────────────────────────
  counterNoticeAt   DateTime?
  counterNoticeBy   String? // user id of the uploader
  counterNoticeText String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([contentIdentifier])
}

// ─── Combat Clips (user-uploaded native-video reels) ─────────────────────

// A user-uploaded fight clip. Stored as a native video file (R2/blob), so it
// autoplays reliably on mobile (unlike YouTube embeds). Rated by the community.


// ─── Community Predictions (native to Combat Register) ───────────────────
// Distinct from the live external market feed (Polymarket/Kalshi, which is
// read-only and lives entirely in src/features/predictions). These are our
// own community questions — "Who wins?", "Will this fight happen?", "Fight of
// the Night?" — that signed-in users vote on. Tallies are denormalised onto
// the market row for fast reads; one vote per user per market (upserted).
model CommunityMarket {
  id               String    @id @default(cuid())
  slug             String    @unique
  kind             String    @default("who_wins") // who_wins | will_happen | fotn | prop
  sport            String // Sport enum value as string (BOXING…)
  league           String? // UFC | Misfits | BKFC …
  title            String
  subtitle         String? // weight class / context line
  description      String?   @db.Text
  status           String    @default("open") // open | closed | resolved
  closesAt         DateTime?
  // options: [{ id, label, sub? }] — the choices users pick between.
  options          Json
  // tally: { [optionId]: count } — denormalised running totals.
  tally            Json?
  voteCount        Int       @default(0)
  featured         Boolean   @default(false)
  hot              Boolean   @default(false)
  seedKey          String?   @unique // maps a seeded fixture → its row
  // When set, this row is the community vote attached to an external market
  // (e.g. "polymarket:0x…" / "kalshi:KX…") rather than a standalone question.
  // Such rows are excluded from the standalone "Fight Pulse" list.
  providerMarketId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  votes CommunityVote[]

  @@index([sport, status])
  @@index([status, voteCount])
}

model CommunityVote {
  id        String          @id @default(cuid())
  marketId  String
  market    CommunityMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  choice    String // an option id from the market
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([marketId, userId]) // one vote per user per market
  @@index([userId])
  @@index([marketId, choice])
}

// ─── Users & accounts (Auth.js model-compatible) ────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  bannerUrl     String? // profile cover image (user-uploaded)
  passwordHash  String? // bcrypt; null for OAuth-only accounts
  // Session epoch. Every issued JWT carries this value; bumping it revokes all
  // outstanding sessions at once (password change / reset / sign-out-everywhere).
  tokenVersion  Int       @default(0)

  // Age declaration. Deliberately an ACKNOWLEDGEMENT, not a date of birth: we need
  // to know you meet the minimum age, and a full birth date is more personal data
  // than that question requires (data minimisation). It is never displayed publicly.
  //
  // This is NOT proof of age and is not presented as such — see /responsible-gambling.
  ageConfirmed     Boolean   @default(false) // "I am at least MINIMUM_AGE"
  ageConfirmedAt   DateTime?
  agePolicyVersion String? // which wording they agreed to
  // Set when a user tells us they are under age: the account is restricted pending
  // deletion rather than silently kept.
  underageFlagged  Boolean   @default(false)
  registryRole     String    @default("fan") // signup intent: fan|fighter|coach|gym|promoter|manager|official|media
  role             UserRole  @default(USER)
  reputation       Int       @default(0)
  // Denormalised prediction record — written only by the resolution engine
  // (src/lib/intelligence/resolve.ts) so accuracy/streak/leaderboard are O(1) reads.
  picksResolved    Int       @default(0)
  picksCorrect     Int       @default(0)
  pickStreak       Int       @default(0) // current consecutive correct picks
  bestPickStreak   Int       @default(0)
  // Denormalised battle record (O(1) profile reads) — written by resolveFightBattles.
  battleWins       Int       @default(0)
  battleLosses     Int       @default(0)
  battleDraws      Int       @default(0)
  battleStreak     Int       @default(0) // current consecutive battle wins
  bestBattleStreak Int       @default(0)
  bio              String?
  /// Disciplines chosen in the first-run flow. A scalar list rather than a join
  /// table: it is a small ordered set read on nearly every personalised query,
  /// so a join would cost a round trip to save nothing.
  sportPrefs       String[]
  /// Stamped when the first-run flow is finished OR skipped. Null means the user
  /// has never seen it — the only condition that routes anyone into onboarding.
  onboardedAt      DateTime?
  localePref       String    @default("en")
  themePref        String    @default("dark")
  createdAt        DateTime  @default(now())

  // ── Community map presence ────────────────────────────────────────────
  // Opt-IN, and opt-in twice: a user is only ever plotted when they have both
  // chosen a visibility other than HIDDEN and told us a city. See the
  // MapVisibility enum for why there is no GPS column here — the point we
  // plot is a city centre they picked, never a device position.
  mapVisibility      MapVisibility @default(HIDDEN)
  mapCity            String?
  mapCountryCode     String?
  /// Resolved from mapCity/mapCountryCode through the gazetteer at save time,
  /// so the people layer is one indexed read instead of N lookups per render.
  mapLat             Float?
  mapLon             Float?
  /// Discoverability flags — these are the map's "role" filters.
  openToSpar         Boolean       @default(false)
  lookingForTraining Boolean       @default(false)

  // ── Notification preferences ──────────────────────────────────────────
  // Categories rather than one switch per notification TYPE: a user thinks
  // "stop telling me about fights", not "disable FIGHT_ANNOUNCED and
  // EVENT_LIVE". Types map onto these in src/lib/push/policy.ts, so adding a
  // NotificationType never requires a migration.
  //
  // Defaults are ON for everything a user opted into by following something,
  // because the notification is the thing they asked for. Push still requires
  // an explicit browser permission on top — see PushSubscription.
  notifyFights      Boolean @default(true)  // reminders, going live, card changes
  notifyPredictions Boolean @default(true)  // lock deadlines, results, rank moves
  notifySocial      Boolean @default(true)  // replies, mentions, follows, battles
  notifyGym         Boolean @default(true)  // check-ins, membership, verification
  /// Local hours [start, end) during which push is withheld. Null = always on.
  /// Stored as plain hours + an IANA zone rather than UTC instants: "no pings
  /// before 8am" has to survive the user travelling.
  quietHoursStart Int?
  quietHoursEnd   Int?
  timezone        String?

  // ── Public identity ───────────────────────────────────────────────────
  // Flat columns rather than a UserSocial join table (the shape Fighter uses):
  // a fixed set of five known platforms is read on every profile render, so a
  // join would cost a round trip to model nothing extra. Fighter's table earns
  // its keep because a fighter's links are editorially curated and open-ended.
  website     String?
  instagram   String?
  twitter     String?
  youtube     String?
  tiktok      String?
  facebook    String?
  /// Fighters only, and self-declared — never presented as a verified record.
  weightClassPref String?
  yearsTraining   Int?

  accounts          Account[]
  sessions          Session[]
  passwordResets    PasswordResetToken[]
  predictions       Prediction[]
  articles          Article[]
  threads           ForumThread[]
  posts             ForumPost[]
  reactions         ForumReaction[]
  subscriptions     ForumSubscription[]
  bookmarks         ForumBookmark[]
  reports           ForumReport[]
  communities       CommunityMember[]
  communityVotes    CommunityVote[]
  favorites         FavoriteFighter[]
  promotionFollows  FavoritePromotion[]
  eventFollows      FavoriteEvent[]
  fightPicks        FightPick[]
  reputationEvents  ReputationEvent[]
  notifications     Notification[]
  activities        Activity[]
  cardAwards        CardAward[]
  battlesChallenged Battle[]             @relation("BattleChallenger")
  battlesOpposed    Battle[]             @relation("BattleOpponent")
  rivalriesA        Rivalry[]            @relation("RivalryA")
  rivalriesB        Rivalry[]            @relation("RivalryB")
  fighterProfile    Fighter?             @relation("FighterOwner")
  claimsMade        FighterClaim[]       @relation("ClaimsMade")
  claimsReviewed    FighterClaim[]       @relation("ClaimsReviewed")
  copyrightReviewed CopyrightReport[]    @relation("CopyrightReviewed")
  gymMemberships    GymMember[]
  gymsOwned         Gym[]                @relation("GymOwner")
  gymClaimsMade     GymClaim[]           @relation("GymClaimsMade")
  gymClaimsReviewed GymClaim[]           @relation("GymClaimsReviewed")
  checkIns          CheckIn[]
  following         UserFollow[]         @relation("Follower")
  followers         UserFollow[]         @relation("Following")
  pushSubscriptions PushSubscription[]

  @@index([reputation])
  // The people layer's hot path: "visible users who have a resolved point".
  @@index([mapVisibility, mapLat])
}

/// Forgotten-password reset tokens.
///
/// Only a SHA-256 hash of the token is stored — a database leak must not yield
/// usable reset links. The raw token exists solely in the emailed URL. Tokens
/// are single-use (`usedAt`), short-lived (`expiresAt`), and superseded: issuing
/// a new token marks every prior unused token for that user as consumed.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256(raw token), hex
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  requestIp String? // for abuse investigation; not shown to users

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model FavoriteFighter {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fighterId String
  fighter   Fighter  @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, fighterId])
}

/// A user following a promotion. Keyed by the promotion REGISTRY slug
/// (resolvePromotion().slug, e.g. "ufc") rather than a Promotion FK, because
/// events carry promotion as a free-text name and the Promotion table is sparse
/// — the registry slug is the stable identifier used across the UI.
model FavoritePromotion {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promotion String
  createdAt DateTime @default(now())

  @@id([userId, promotion])
  @@index([promotion])
}

/// A followed EVENT — the highest-intent follow there is: it means "remind me
/// about this card". Distinct from following a promotion (a standing interest);
/// this is a commitment to one date, and it's what the reminder scheduler and
/// the Following feed key off.
model FavoriteEvent {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, eventId])
  @@index([eventId])
  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Scraper bookkeeping ────────────────────────────────────────────────

model ScrapeJob {
  id         String       @id @default(cuid())
  target     String // "rankings:heavyweight", "fighter:12345"
  status     ScrapeStatus @default(PENDING)
  attempts   Int          @default(0)
  error      String?      @db.Text
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([status, createdAt])
  @@index([target])
}

// ════════════════════════════════════════════════════════════════════════
//  Multi-source data-intelligence layer
//  Registry of providers + their health/sync telemetry, and the canonical
//  identity maps (external ids / aliases) used by the dedupe engine.
//  See src/services/{providers,aggregator,dedupe,normalization}.
// ════════════════════════════════════════════════════════════════════════

enum DataSourceKind {
  API
  SCRAPER
  MANUAL
}

model DataSource {
  id             String         @id @default(cuid())
  key            String         @unique // "sportradar", "tapology", "api-sports", "scraper"
  label          String
  kind           DataSourceKind @default(API)
  baseConfidence Float          @default(0.5) // 0..1 default trust weight
  enabled        Boolean        @default(true)
  createdAt      DateTime       @default(now())

  health ProviderHealth[]
  syncs  ProviderSync[]
}

model ProviderHealth {
  id          String     @id @default(cuid())
  sourceKey   String
  source      DataSource @relation(fields: [sourceKey], references: [key], onDelete: Cascade)
  ok          Boolean    @default(true)
  latencyMs   Int?
  rateLimited Boolean    @default(false)
  error       String?    @db.Text
  checkedAt   DateTime   @default(now())

  @@index([sourceKey, checkedAt])
}

model ProviderSync {
  id            String     @id @default(cuid())
  sourceKey     String
  source        DataSource @relation(fields: [sourceKey], references: [key], onDelete: Cascade)
  sport         String? // Sport enum value, or null = all
  entity        String // events | fighters | rankings | results | news
  status        String     @default("RUNNING") // RUNNING | SUCCESS | FAILED | FALLBACK
  imported      Int        @default(0)
  updated       Int        @default(0)
  rejected      Int        @default(0)
  failures      Int        @default(0)
  rateLimitHits Int        @default(0)
  durationMs    Int?
  fellBackTo    String? // source key the run fell back to
  error         String?    @db.Text
  startedAt     DateTime   @default(now())
  finishedAt    DateTime?

  @@index([sourceKey, startedAt])
  @@index([entity, status])
}

model FighterExternalId {
  id         String   @id @default(cuid())
  fighterId  String
  fighter    Fighter  @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  source     String // "tapology" | "sportradar" | ...
  externalId String
  confidence Float    @default(1)
  createdAt  DateTime @default(now())

  @@unique([source, externalId])
  @@index([fighterId])
}

model EventExternalId {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source     String
  externalId String
  confidence Float    @default(1)
  createdAt  DateTime @default(now())

  @@unique([source, externalId])
  @@index([eventId])
}

model FighterAlias {
  id         String   @id @default(cuid())
  fighterId  String
  fighter    Fighter  @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  alias      String // raw alias as seen upstream
  normalized String // normalized form for matching
  source     String?
  createdAt  DateTime @default(now())

  @@index([normalized])
  @@index([fighterId])
}

// ─── Promotion Registry ─────────────────────────────────────────────────
// Canonical list of combat-sports promotions, seeded from the Global Combat
// Sports Promotions Registry workbook and kept live by ingestion. Promotion
// is the parent entity that news Articles and Events resolve to; per-promotion
// ingestion source URLs live on PromotionSource (the DB-backed source table
// the pipeline previously lacked — sources used to be hardcoded arrays).

enum PromotionStatus {
  VERIFIED_ACTIVE
  ACTIVE_RECURRING
  ACTIVE_SPORADIC
  ANNOUNCED
  ACTIVITY_UNCLEAR
  DORMANT
  DEFUNCT
}

enum PromotionSourceType {
  OFFICIAL_SITE
  NEWS
  PRESS
  RSS
  SCHEDULE // upcoming events / calendar page
  RESULTS
  YOUTUBE
  INSTAGRAM
  FACEBOOK
  TWITTER // X
  TIKTOK
  AGGREGATOR // tapology / sherdog / espn secondary source
}

model Promotion {
  id           String          @id @default(cuid())
  slug         String          @unique // slugify(name)
  name         String
  acronym      String?
  sport        Sport // mapped from registry "Sport"
  ruleset      String? // raw "Ruleset / Discipline" text
  country      String?
  countryCode  String?
  region       String?
  scope        String? // "Geographic Scope"
  entityType   String? // "Commercial promotion", "Federation-operated"...
  status       PromotionStatus @default(ACTIVE_RECURRING)
  officialUrl  String? // "Primary Source URL"
  secondaryUrl String? // "Secondary Source URL"
  confidence   String? // "High" | "Medium" | "Low"
  evidence     String?         @db.Text // "Evidence / Recency"
  notes        String?         @db.Text
  active       Boolean         @default(true) // false = dormant/defunct
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sources  PromotionSource[]
  articles Article[]
  events   Event[]

  @@index([sport, status])
  @@index([country])
  @@index([active])
}

model PromotionSource {
  id            String              @id @default(cuid())
  promotionId   String
  promotion     Promotion           @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  type          PromotionSourceType
  url           String
  label         String?
  method        String? // "rss-syndication" | "scrape" | "link-only"
  official      Boolean             @default(true)
  enabled       Boolean             @default(true) // gated by ingestion policy; link-only sources are not fetched
  lastFetchedAt DateTime?
  lastStatus    String?
  discoveredAt  DateTime            @default(now())

  @@unique([promotionId, url])
  @@index([type, enabled])
  @@index([promotionId])
}

// News outlets / media platforms — the press side of the registry, seeded from
// the Global Combat-Sports News Platforms directory. These are RSS/syndication
// sources for the news pipeline (distinct from Promotion, which is the org).
model NewsOutlet {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  website   String
  sports    Sport[] // multi-discipline outlets carry several
  region    String?
  language  String?
  notes     String?  @db.Text
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

// ─── Combat Feed ────────────────────────────────────────────────────────
// Video catalog + per-user feed state. `key` is the feed identity: an
// authenticated user id when signed in (so preferences follow the account
// across devices), otherwise the anonymous browser client id.

model FeedVideo {
  id          String    @id // YouTube video id
  title       String
  channel     String
  channelId   String?
  description String?
  publishedAt DateTime?
  viewCount   Int?
  topic       String?
  tags        String[]
  /// Promotion slug from lib/promotions ("ufc", "bkfc"…), or null for
  /// independent media. Stamped from the trusted channel entry, never guessed
  /// from the payload — it is what FavoritePromotion rows are keyed by, so a
  /// wrong value here means notifying the wrong followers.
  promotion   String?
  /// Discipline slug matching SPORT_PILLS ("mma", "boxing", "muay-thai"…), so
  /// a video filters by the same vocabulary as ?sport= everywhere else.
  discipline  String?
  addedAt     DateTime  @default(now())

  discussions ForumThread[]

  @@index([addedAt])
  @@index([topic])
  @@index([promotion, publishedAt])
  @@index([discipline, publishedAt])
}

/// Cross-instance job leases — see src/lib/job-lease.ts. Replaces session-scoped
/// pg_advisory_lock, which leaked across Prisma's connection pool and wedged
/// feed ingestion after a single run. Rows are disposable: an expired lease is
/// simply claimable again.
model JobLease {
  name      String   @id
  expiresAt DateTime
}

model FeedView {
  key      String
  videoId  String
  servedAt DateTime @default(now())

  @@id([key, videoId])
  @@index([key])
}

model FeedHiddenChannel {
  key       String
  channelId String

  @@id([key, channelId])
}

model FeedNotInterested {
  key     String
  videoId String

  @@id([key, videoId])
}

model FeedInterest {
  key    String
  tag    String
  weight Float  @default(0)

  @@id([key, tag])
}

// ─── Combat Feed · Personal Library ─────────────────────────────────────
// Saved videos, Watch Later, Favorites and user-made Collections. `key` is the
// feed identity (authed user id when signed in, else anonymous client id), same
// as the other feed tables. Item rows snapshot the video's display fields so a
// saved video still renders even after it ages out of the rolling catalog.

model FeedCollection {
  id        String               @id @default(cuid())
  key       String
  name      String
  system    String? // "watch_later" | "favorites" | null (user-created)
  createdAt DateTime             @default(now())
  items     FeedCollectionItem[]

  @@unique([key, system]) // at most one of each system collection per key
  @@index([key])
}

model FeedCollectionItem {
  collectionId String
  videoId      String
  title        String
  channel      String
  channelId    String?
  topic        String?
  addedAt      DateTime       @default(now())
  collection   FeedCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([collectionId, videoId])
  @@index([videoId])
}

// ─── Combat Intelligence Engine ─────────────────────────────────────────────
// The single systems every engagement mechanic fans into. The resolution
// pipeline (src/lib/intelligence/resolve.ts) is the only writer of reputation +
// pick stats; these tables are the durable record it and future sources emit to.

/// Append-only reputation ledger. `User.reputation` is the running total; this
/// explains every point so the score is auditable and recomputable. ONE score,
/// many sources (correct picks now; forum upvotes, verified roles, streaks later).
model ReputationEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String // "pick_correct" | "pick_streak" | "forum_upvote" | …
  refType   String? // "fight" | "post" | …
  refId     String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum NotificationType {
  PICK_RESULT
  CARD_EARNED
  REP_MILESTONE
  FIGHT_ANNOUNCED
  EVENT_LIVE
  FOLLOW
  COMMUNITY_REPLY
  BATTLE_RESULT
  BATTLE_MATCHED // an opponent took the other side — the room is live
  BATTLE_REPLY // your rival spoke in the battle room
  SYSTEM
}

/// Personal, user-targeted notifications (distinct from /api/notifications, which
/// is a computed public content ticker). Written by notify() from any subsystem.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  url       String?
  icon      String? // optional emoji key for the UI
  // Idempotency for SCHEDULED notifications (Return Engine): e.g.
  // "event_soon:<eventId>". Null for one-off notifications (pick results). The
  // unique guarantees a given reminder is delivered to a user at most once, so
  // the scheduler can re-run safely and use createMany(skipDuplicates).
  dedupeKey String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  // The scheduler looks rows up by dedupeKey ALONE (which of this batch already
  // existed?), and the composite above cannot serve that — its leading column is
  // userId. Measured as a Seq Scan: harmless at 500 rows, a full table scan per
  // event per cron tick once this table has a year of history in it.
  @@index([dedupeKey])
}

enum ActivityType {
  PICK_MADE
  PICK_CORRECT
  CARD_EARNED
  REP_MILESTONE
  FOLLOW
  THREAD_CREATED
  BATTLE_WON
}

/// One shared activity stream. Everything a user does that's worth surfacing
/// emits here; the homepage/profile feeds read from it.
model Activity {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  title     String
  url       String?
  meta      Json?
  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

enum CardRarity {
  BASE
  RARE
  EPIC
  CHAMPION
  LEGEND
}

/// A collectible fighter card a user has EARNED (the collectible-infrastructure
/// spine — no gambling). Rarity is derived from the bout's stakes. Marketplace/
/// packs build on this ownership record later.
model CardAward {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fighterId String
  fighter   Fighter    @relation(fields: [fighterId], references: [id], onDelete: Cascade)
  rarity    CardRarity
  reason    String // "correct_pick" | "streak_milestone" | …
  fightId   String?
  createdAt DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([fighterId])
}

// ─── Prediction Battles (PvP) ───────────────────────────────────────────────
// Every prediction can create an adversary: two users who picked OPPOSITE corners
// on the same bout are paired into a Battle. The fight itself is the referee — the
// resolution engine reads each side's graded FightPick.correct and declares the
// winner. No moderators, no voting. Battle stakes layer onto the ONE reputation
// score; Rivalry persists head-to-head history for future rival pages / ladders.

enum BattleState {
  WAITING // challenger in, awaiting an opponent
  ACTIVE // both sides matched
  RESOLVED // fight decided, winner set (or draw)
  CANCELLED // withdrawn
  EXPIRED // fight passed with no opponent
}

model Battle {
  id      String @id @default(cuid())
  fightId String
  fight   Fight  @relation(fields: [fightId], references: [id], onDelete: Cascade)

  challengerId         String
  challenger           User         @relation("BattleChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  // Snapshots for display only — the WINNER is decided from the graded FightPick,
  // so editing a pick after matching is handled correctly.
  challengerCorner     String
  challengerMethod     FightMethod?
  challengerConfidence Int?

  opponentId         String?
  opponent           User?        @relation("BattleOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  opponentCorner     String?
  opponentMethod     FightMethod?
  opponentConfidence Int?

  state          BattleState  @default(WAITING)
  winnerId       String? // User.id, or null for a draw/void
  loserId        String?
  resolvedSource String? // "fight_result"
  messageCount   Int          @default(0)
  /// The battle's PRIVATE room (visibility="battle"), provisioned on first open.
  room           ForumThread?

  createdAt  DateTime  @default(now())
  matchedAt  DateTime?
  resolvedAt DateTime?
  updatedAt  DateTime  @updatedAt
  // At most one OPEN battle per challenger per fight is enforced in the pairing
  // transaction (a partial unique isn't expressible in Prisma).

  @@index([fightId, state])
  @@index([challengerId, state])
  @@index([opponentId, state])
}

/// Persisted head-to-head between two users (never computed per-request). The pair
/// is stored canonically with userAId < userBId so it is unique and O(1) to look up.
model Rivalry {
  id                  String   @id @default(cuid())
  userAId             String
  userA               User     @relation("RivalryA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId             String
  userB               User     @relation("RivalryB", fields: [userBId], references: [id], onDelete: Cascade)
  aWins               Int      @default(0) // battles userA won
  bWins               Int      @default(0)
  draws               Int      @default(0)
  currentStreakUserId String? // who is on the active win streak
  currentStreak       Int      @default(0)
  bestStreakUserId    String?
  bestStreak          Int      @default(0)
  totalMessages       Int      @default(0)
  firstBattleAt       DateTime @default(now())
  lastBattleAt        DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// ─── Analytics (first-party, cookieless) ────────────────────────────────────
// The innovation-accounting instrument. First-party only — NO third-party
// scripts, NO tracking cookie (preserving the documented privacy posture).
// Signed-in events carry userId (the north-star audience is registered
// predictors); anonymous events are recorded with no identity, for aggregate
// volume only. Append-only; never blocks a request (recordEvent swallows errors).
model AnalyticsEvent {
  id     String   @id @default(cuid())
  name   String // allow-listed event name (see src/lib/analytics.ts)
  userId String? // set when signed in; no anonymous cross-session id
  path   String? // route, for pageviews
  props  Json?
  ts     DateTime @default(now())

  @@index([name, ts])
  @@index([userId, ts])
}

// ═══════════════════════════════════════════════════════════════════════════
//  COMMUNITY MAP — gyms, people, presence
//
//  The Location pillar started as an event map. These models turn it into a
//  network: places people belong to, people who opt in to being seen, and a
//  lightweight presence signal that says who is actually there right now.
//
//  Three rules run through all of it:
//
//   1. NOBODY IS ON THE MAP BY DEFAULT. MapVisibility defaults to HIDDEN and
//      every people-layer query filters on it server-side. A UI toggle is not
//      a privacy control.
//   2. WE NEVER STORE A USER'S GPS POSITION. A person's map point is the
//      CENTRE OF A CITY THEY CHOSE, resolved through the same gazetteer the
//      events use. That is enough to find training partners and not enough to
//      find someone's house — and it cannot leak precision we never held.
//   3. PRESENCE EXPIRES. A check-in is a few hours of "I'm here", not a
//      permanent location history. Expired rows stop matching every query.
// ═══════════════════════════════════════════════════════════════════════════

/// Who may see a user on the map. HIDDEN is the default and the fallback for
/// any value the server does not recognise.
enum MapVisibility {
  HIDDEN
  PUBLIC
  FOLLOWERS /// people they follow back — the "friends only" setting
  GYM_MEMBERS /// members of a gym they belong to
  EVENTS_ONLY /// only while checked in to an event
}

/// A training location: gym, academy, club room, boxing gym, wrestling room.
/// First-class and claimable — the combat-sports equivalent of a Google
/// Business Profile.
model Gym {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  logoUrl String?
  heroUrl String?

  /// Location. `latitude`/`longitude` are real columns here (unlike Event,
  /// which is still gazetteer-resolved) because a gym IS an address — it is
  /// the thing being looked up, and "somewhere in this city" is not good
  /// enough to drive to. Null until geocoded; the map lists those separately
  /// rather than guessing.
  address     String?
  city        String?
  region      String?
  country     String?
  countryCode String?
  latitude    Float?
  longitude   Float?

  /// What is actually taught here — drives the discipline filter.
  disciplines String[]

  website   String?
  instagram String?
  facebook  String?
  youtube   String?
  tiktok    String?
  phone     String?
  email     String?
  /// Free text ("Mon–Fri 6am–9pm · Open mat Sat 11am"). Structured opening
  /// hours are a real modelling job and this is honest until then.
  hoursNote String?

  /// Set by a reviewed GymClaim. Never by the owner directly.
  verified   Boolean @default(false)
  ownerId    String?
  owner      User?   @relation("GymOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  /// Denormalised so a map pin never counts rows.
  memberCount Int    @default(0)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  GymMember[]
  claims   GymClaim[]
  checkIns CheckIn[]
  photos   GymPhoto[]

  @@index([countryCode])
  @@index([latitude, longitude])
}

/// Membership. `isHome` is the one a fighter calls their home gym — at most
/// one per user, enforced in the service layer.
model GymMember {
  id     String @id @default(cuid())
  gymId  String
  gym    Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// member | coach | owner
  role   String @default("member")
  isHome Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([gymId, userId])
  @@index([userId, isHome])
}

/// Ownership claim over a gym page. Mirrors FighterClaim's shape deliberately:
/// same review vocabulary, same admin habits, no second concept to learn.
model GymClaim {
  id        String @id @default(cuid())
  gymId     String
  gym       Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  claimantId String
  claimant  User   @relation("GymClaimsMade", fields: [claimantId], references: [id], onDelete: Cascade)

  /// pending | approved | rejected | info_requested
  status  String  @default("pending")
  /// How they say they can prove it (role, website email, socials).
  evidence String?
  note     String?

  // ── Uploaded proof (business licence, utility bill, signage photo) ────────
  // Column-for-column the same shape as FighterClaim so ONE evidence pipeline
  // (src/lib/evidence/*) serves both: private bucket, virus scan, retention
  // deadline, audited deletion. These bytes are NEVER public and have no URL —
  // they are streamed by an authorised reader only.
  evidenceStorageKey      String? // opaque object key; never returned to clients
  evidenceStorageProvider String? // "r2" | "local-private"
  evidenceUploadedAt      DateTime?
  evidenceDeleteAfter     DateTime? // retention deadline; cleanup job deletes past this
  evidenceDeletedAt       DateTime?
  evidenceDeletionStatus  String? // null | PENDING | DELETED | FAILED
  evidenceDeletionError   String?
  evidenceScanStatus      String? // PENDING | CLEAN | INFECTED | SKIPPED
  evidenceContentType     String?
  evidenceByteSize        Int?

  reviewerId String?
  reviewer   User?     @relation("GymClaimsReviewed", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status, createdAt])
  @@index([claimantId])
  @@index([evidenceDeleteAfter])
}

/// "I'm here." Presence, not location history — `expiresAt` is what keeps this
/// from becoming a tracking log, and every read filters on it.
model CheckIn {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymId   String?
  gym     Gym?    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// Optional short status ("open mat", "watching the prelims").
  note    String?

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([gymId, expiresAt])
  @@index([eventId, expiresAt])
  @@index([userId, expiresAt])
}

/// The user→user social graph. Nothing in the schema modelled "I follow this
/// person" — favourites covered fighters, promotions and events only — so
/// "Friends Only" visibility had nothing to resolve against and the Following
/// pillar had no people in it. One row per direction; mutual follow is both.
model UserFollow {
  id          String @id @default(cuid())
  followerId  String
  follower    User   @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

/// A gallery image on a gym page. Stores BOTH the full and thumb URLs the image
/// pipeline returns, plus the intrinsic dimensions — a gallery that renders
/// without width/height reflows the whole page as each image lands.
model GymPhoto {
  id      String @id @default(cuid())
  gymId   String
  gym     Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  url      String
  thumbUrl String
  width    Int    @default(0)
  height   Int    @default(0)
  /// Shown under the image in the viewer.
  caption  String?
  /// Screen-reader description. Distinct from caption on purpose: a caption is
  /// editorial ("Saturday open mat"), alt text describes what is IN the frame
  /// for someone who cannot see it. Using one for both fails whichever reader
  /// you did not have in mind.
  alt      String?
  /// Photo credit, when a gym is publishing someone else's work.
  credit   String?
  takenAt  DateTime?

  /// Manual ordering; ties break on createdAt.
  sortOrder Int   @default(0)

  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([gymId, sortOrder])
}

/// A browser's Web Push endpoint. One row per DEVICE, not per user — a person
/// with a phone and a laptop gets both, and revoking one must not silence the
/// other.
///
/// `endpoint` is unique: re-subscribing the same browser updates the keys
/// rather than accumulating dead rows. `failedCount` lets delivery prune
/// endpoints the push service has permanently rejected (410/404) instead of
/// retrying them forever.
model PushSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  /// Client public key + auth secret from the browser's subscription.
  p256dh   String
  auth     String

  userAgent   String?
  failedCount Int      @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}
