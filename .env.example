# ── GlobalFight — environment template ─────────────────────────────────────
# Copy to .env for local dev, or paste into Render → Environment.
# NEVER commit a real .env (it is gitignored).

# ── Core ───────────────────────────────────────────────────────────────────
NODE_ENV="production"
# Render → your Postgres instance → "Internal Database URL".
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB"
# 64 hex chars. Generate a NEW one for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""
NEXT_PUBLIC_SITE_URL="https://your-app.onrender.com"

# ── Cron auth ──────────────────────────────────────────────────────────────
# Generate a new strong secret; set BOTH to the same value.
# cron-handler.ts accepts either (CRON_SECRET is the Vercel convention).
SCRAPE_CRON_SECRET=""
CRON_SECRET=""

# ── Ingestion master gate ──────────────────────────────────────────────────
# Required for ANY scrape fetch. Per-source writes are additionally gated by
# src/lib/ingestion-registry.ts (the bkfc-*/one-*/adcc-* entries are enabled by
# an OPERATOR OVERRIDE for dev — NOT a licence. Get written permission before
# production/public use).
ENABLE_SCRAPER="false"
SCRAPER_RATE_LIMIT_MS="800"
SCRAPER_MAX_RETRIES="2"
BKFC_CONCURRENCY="3"
BKFC_MAX_PAGES="0"
ONE_CONCURRENCY="3"
ONE_MAX_PAGES="0"
WIKICARD_BATCH="40"
WIKICARD_CONCURRENCY="2"

# ── Licensed APIs (copy values from your local .env) ────────────────────────
ODDS_API_KEY=""
API_SPORTS_KEY=""

# ── Fighter photos / enrichment ────────────────────────────────────────────
MEDIA_INGESTION_ENABLED="true"
ENRICH_BATCH="30"

# ── Image storage ──────────────────────────────────────────────────────────
# public/headshots is gitignored (225MB of generated black-bg photos), so it is
# NOT deployed. To serve fighter photos in production, upload them to R2/S3 and
# point imageUrl at the CDN (next.config + media-safe already allow **.r2.dev /
# **.public.blob.vercel-storage.com as "own storage").
STORAGE_PROVIDER=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""
R2_PUBLIC_BASE_URL=""

# ── Optional ───────────────────────────────────────────────────────────────
LOG_LEVEL="info"
# REDIS_URL=""          # falls back to an in-process cache when unset
# USE_MOCK_DATA="false" # real Postgres is the default

# ── Seed World — single source of truth: SEED_WORLD_MODE ─────────────────────
#   off | (unset) → never seed; leave any existing seed data untouched.
#   demo          → on startup, seed once if the DB has no seed users (idempotent);
#                   also shows the transparent "Demo World" badge + footer.
#   refresh       → wipe + regenerate once per deploy, then behave as demo.
# Populates ~70 marked (@seed.local) users + predictions, discussions, cards,
# notifications, activity. Reset (remove all seed data) via the admin endpoint:
#   POST /api/admin/seed-world/reset  (Authorization: Bearer <SEED_WORLD_ADMIN_TOKEN>)
SEED_WORLD_MODE="off"
# Bearer token for the reset endpoint above.
# SEED_WORLD_ADMIN_TOKEN=""

# ── Location pillar — map basemap ────────────────────────────────────────────
# The /map basemap. Defaults to CARTO's dark raster tiles over OpenStreetMap
# data, attributed in-map as both licences require. Point these at Mapbox, a
# Google raster proxy or a self-hosted style to swap providers without a code
# change. Both are NEXT_PUBLIC_ — they are fetched by the browser.
# NEXT_PUBLIC_MAP_TILE_URL="https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png"
# NEXT_PUBLIC_MAP_TILE_ATTRIBUTION="&copy; OpenStreetMap &copy; CARTO"

# ── Transactional email (password reset) ─────────────────────────────────────
# The reset flow is fully built: rate-limited per-IP and per-account,
# enumeration-safe (identical response whether or not the address exists), and
# one-time tokens that expire. The ONLY missing piece is a provider.
#
# Until these are set, production returns 503 for a reset request rather than
# saying "check your inbox" for a mail that was never sent — see
# src/lib/email/send.ts. In development the reset LINK is written to the server
# log instead, so you can test the flow without a provider.
#
# Resend is the implemented provider (plain HTTPS, no SDK dependency).
# EMAIL_FROM must be an address on a domain you have verified with them.
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY=""
# EMAIL_FROM="Combat Reviews <no-reply@yourdomain.com>"
#
# Also required for the link in the email to point anywhere real:
# NEXT_PUBLIC_SITE_URL="https://globalfight.onrender.com"

# ── Image uploads (gym logo / hero / gallery, user avatars) ──────────────────
# ALL public media uploads are gated by this ONE flag, and it fails closed.
# The gate exists because there is no malware scanner and no moderation queue
# (see src/lib/ugc-guard.ts) — the app refuses an upload rather than publish a
# file it cannot scan. Gym owners are verified humans but are not a trusted
# binary source, so gym media gets no exemption.
#
# With this unset/false: the uploader shows the server's real 503 reason.
# With it "true": logo, hero and gallery uploads work end-to-end.
UGC_MEDIA_UPLOADS_ENABLED="false"
#
# Where the processed WebP files are stored. First match wins:
#   Vercel Blob → BLOB_READ_WRITE_TOKEN
#   Cloudflare R2 / S3 → R2_* (or S3_*) below
#   neither → public/ on local disk (dev only; Render's disk is ephemeral)
# BLOB_READ_WRITE_TOKEN=""
