# ── GlobalFight — environment template ─────────────────────────────────────
# Copy to .env for local dev, or paste into Render → Environment.
# NEVER commit a real .env (it is gitignored).

# ── Core ───────────────────────────────────────────────────────────────────
NODE_ENV="production"
# Render → your Postgres instance → "Internal Database URL".
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB"
# 64 hex chars. Generate a NEW one for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""
NEXT_PUBLIC_SITE_URL="https://your-app.onrender.com"

# ── Cron auth ──────────────────────────────────────────────────────────────
# Generate a new strong secret; set BOTH to the same value.
# cron-handler.ts accepts either (CRON_SECRET is the Vercel convention).
SCRAPE_CRON_SECRET=""
CRON_SECRET=""

# ── Ingestion master gate ──────────────────────────────────────────────────
# Required for ANY scrape fetch. Per-source writes are additionally gated by
# src/lib/ingestion-registry.ts (the bkfc-*/one-*/adcc-* entries are enabled by
# an OPERATOR OVERRIDE for dev — NOT a licence. Get written permission before
# production/public use).
ENABLE_SCRAPER="false"
SCRAPER_RATE_LIMIT_MS="800"
SCRAPER_MAX_RETRIES="2"
BKFC_CONCURRENCY="3"
BKFC_MAX_PAGES="0"
ONE_CONCURRENCY="3"
ONE_MAX_PAGES="0"
WIKICARD_BATCH="40"
WIKICARD_CONCURRENCY="2"

# ── Licensed APIs (copy values from your local .env) ────────────────────────
ODDS_API_KEY=""
API_SPORTS_KEY=""

# ── Fighter photos / enrichment ────────────────────────────────────────────
MEDIA_INGESTION_ENABLED="true"
ENRICH_BATCH="30"

# ── Image storage ──────────────────────────────────────────────────────────
# public/headshots is gitignored (225MB of generated black-bg photos), so it is
# NOT deployed. To serve fighter photos in production, upload them to R2/S3 and
# point imageUrl at the CDN (next.config + media-safe already allow **.r2.dev /
# **.public.blob.vercel-storage.com as "own storage").
STORAGE_PROVIDER=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""
R2_PUBLIC_BASE_URL=""

# ── Optional ───────────────────────────────────────────────────────────────
LOG_LEVEL="info"
# REDIS_URL=""          # falls back to an in-process cache when unset
# USE_MOCK_DATA="false" # real Postgres is the default
